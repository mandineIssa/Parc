# Copier vers .env.testing ou exporter ces variables avant `php artisan test`.
# Les migrations métier (ex. MODIFY colonnes) sont pensées pour MySQL/MariaDB, pas SQLite.

APP_ENV=testing
APP_DEBUG=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=testing
DB_USERNAME=root
DB_PASSWORD=
